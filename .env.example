# ─── Required ───────────────────────────────────────────────

# Server port
PORT=7050

# Groq API key — powers AI routing and response formatting
# Get one at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Telegram bot token — from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ─── Required for Web Search ─────────────────────────────────

# LangSearch API key — enables the webSearch tool
# Get one at https://docs.langsearch.com
LANGSEARCH_API_KEY=sk_your_key_here

# ─── Optional ───────────────────────────────────────────────

# Google AI key — used by some AI providers
GOOGLE_GENERATIVE_AI_API_KEY=your_key_here

# Twitter API Keys (legacy — fallback if OAuth tokens not in memory)
CONSUMER_KEY=your_consumer_key
SECRET_KEY=your_secret_key
BEARER_TOKEN=your_bearer_token
TWITTER_Access_Token=your_access_token
TWITTER_Refresh_Token=your_refresh_token

# Twitter OAuth 2.0 (required for posting tweets)
CLIENT_ID=your_oauth2_client_id
CLIENT_SECRET=your_oauth2_client_secret
X_CALLBACK_URL=https://your-domain.com/telegram/x/callback

# LinkedIn (required for posting on LinkedIn)
# Create an app at https://developer.linkedin.com/ and add
# "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn"
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=https://your-domain.com/telegram/in/callback
LINKEDIN_ACCESS_TOKEN=your_access_token_here
